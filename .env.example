# Server-only database connection string for Neon Postgres.
# Vercel's Neon integration commonly provides DATABASE_URL, but the app also
# supports NEON_DATABASE_URL, POSTGRES_URL, POSTGRES_PRISMA_URL,
# POSTGRES_URL_NON_POOLING, and DATABASE_URL_UNPOOLED.
DATABASE_URL=

# Required for sending manual welcome texts from /subscribers.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Use either a messaging service SID or a from number.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
